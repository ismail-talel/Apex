PORT=5000
MONGODB_URI=mongodb://localhost:27017/smart_parking_db
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:4201
BACKEND_URL=http://localhost:5000

# ─── WebAuthn (Passkeys / biométrie appareil) ────────────────────────────────
WEBAUTHN_RP_NAME=Apex Parking
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:4201

# ─── Amazon Rekognition (reconnaissance faciale) ─────────────────────────────
# En développement sans credentials AWS, le mode MOCK est activé automatiquement
# REKOGNITION_MOCK=true
MOCK_FACE_MATCH_THRESHOLD=40
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
REKOGNITION_COLLECTION_ID=apex-users-faces
FACE_MATCH_THRESHOLD=90

# ─── Konnect (passerelle de paiement tunisienne) ─────────────────────────────
# Sandbox : https://dashboard.sandbox.konnect.network
# Production : https://dashboard.konnect.network
KONNECT_SANDBOX=true
KONNECT_API_KEY=
KONNECT_WALLET_ID=
# KONNECT_MOCK=true  # Force le mode simulation sans clés API

# ─── Mistral IA (assistant parking) ───────────────────────────────────────────
MISTRAL_API_KEY=
# Modèle rapide recommandé : mistral-small-latest
MISTRAL_MODEL=mistral-small-latest
# MISTRAL_FORMAT_MODEL=mistral-small-latest
# IA_MAX_HISTORY=16
# IA_SESSION_TTL_MS=1800000
# IA_RATE_MAX=25
# IA_RATE_WINDOW_MS=60000
