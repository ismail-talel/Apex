PORT=5000
MONGODB_URI=mongodb://localhost:27017/smart_parking_db
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:4201
BACKEND_URL=http://localhost:5000

# ─── Konnect (passerelle de paiement tunisienne) ─────────────────────────────
# Sandbox : https://dashboard.sandbox.konnect.network
# Production : https://dashboard.konnect.network
KONNECT_SANDBOX=true
KONNECT_API_KEY=
KONNECT_WALLET_ID=
# KONNECT_MOCK=true  # Force le mode simulation sans clés API

# ─── Mistral IA (assistant parking) ───────────────────────────────────────────
MISTRAL_API_KEY=
# Modèle rapide recommandé : mistral-small-latest
MISTRAL_MODEL=mistral-small-latest
# MISTRAL_FORMAT_MODEL=mistral-small-latest
# IA_MAX_HISTORY=16
# IA_SESSION_TTL_MS=1800000
# IA_RATE_MAX=25
# IA_RATE_WINDOW_MS=60000
